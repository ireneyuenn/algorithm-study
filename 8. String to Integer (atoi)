def myAtoi(s):
    i = 0
    n = len(s)

    while i < n and s[i].isspace():
        i += 1
    if i == n:
        return 0
    sign = 1

    if s[i] == '-':
        sign = -1
        i += 1
    elif s[i] == '+':
        i += 1
    num = 0

    while i < n and s[i].isdigit():
        digit = int(s[i])

        if sign == 1 and (num > (2**31 - 1) // 10 or (num == (2**31 - 1) // 10 and digit > 7)):
            return 2**31 - 1
        if sign == -1 and (num > 2**31 // 10 or (num == 2**31 // 10 and digit > 8)):
            return -2**31
        num = num * 10 + digit
        i += 1
    return sign * num
