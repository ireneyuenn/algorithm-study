def searchRange(nums, target):
    def left_bound():
        left, right = 0, len(nums)-1
        while left <= right:
            mid = (left+right)//2
            if nums[mid] >= target:
                right = mid -1
            else:
                left = mid +1
        return left
    
    def right_bound():
        left, right = 0, len(nums)-1
        while left <= right:
            mid = (left+right)//2
            if nums[mid] <= target:
                left = mid +1
            else:
                right = mid -1
        return right
    
    left = left_bound()
    right = right_bound()
    if left <= right and left < len(nums) and nums[left] == target:
        return [left, right]
    return [-1, -1]
