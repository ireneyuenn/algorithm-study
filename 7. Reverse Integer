class Solution:
    def reverse(self, x: int) -> int:
        sign = -1 if x < 0 else 1
        x = abs(x)
        reversed_num = 0
        while x:
            digit = x % 10
            if (reversed_num > 2**31 // 10) or (reversed_num == 2**31 // 10 and digit > (7 if sign == 1 else 8)):
                return 0
            reversed_num = reversed_num * 10 + digit
            x //= 10
        return sign * reversed_num
